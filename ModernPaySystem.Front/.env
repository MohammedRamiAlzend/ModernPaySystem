# اعدادات المشروع
# ----------------------------------
# تقاس بل ميلي سيكند اي 5000 هي 5 ثوان
VITE_LIVE_REFETCH_INTERVAL=5000
# اتاحو امكانية للمستخدم ب اختيار النظام الفرعي 
VITE_SHOW_SUB_SYSTEM=false
# النظام الفرعي المختار 
# 0 None 
# 1 transactionSystem
VITE_DEFAULT_SUB_SYSTEM_ID=1
# وضع تطوير عرض الخطأ في صفحة الاخطاء 
VITE_DEV=true